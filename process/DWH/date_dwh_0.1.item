      <column comment="" key="false" length="-1" name="Trimestre" nullable="true" pattern="" precision="-1" sourceType="" type="id_String" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="ID_Mois" nullable="true" pattern="" precision="-1" sourceType="" type="id_Integer" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="Mois" nullable="true" pattern="" precision="-1" sourceType="" type="id_Integer" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="Lib_Mois" nullable="true" pattern="" precision="-1" sourceType="" type="id_String" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="Jour" nullable="true" pattern="" precision="-1" sourceType="" type="id_Integer" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="Id_Lib_Jour" nullable="true" pattern="" precision="-1" sourceType="" type="id_Integer" originalLength="-1" usefulColumn="true"/>
