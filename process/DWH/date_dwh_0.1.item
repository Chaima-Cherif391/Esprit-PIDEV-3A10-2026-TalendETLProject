      <column comment="" key="false" length="-1" name="Semaine" nullable="true" pattern="" precision="-1" sourceType="" type="id_Integer" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="JourDeAnnee" nullable="true" pattern="" precision="-1" sourceType="" type="id_Integer" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="Jour_mois_lettre" nullable="true" pattern="" precision="-1" sourceType="" type="id_String" originalLength="-1" usefulColumn="true"/>
    </metadata>
    <nodeData xsi:type="TalendMapper:MapperData">
      <uiProperties shellMaximized="true"/>
      <varTables sizeState="INTERMEDIATE" name="Var">
        <mapperTableEntries name="date" expression="TalendDate.addDate(&#xD;&#xA;    TalendDate.parseDate(&quot;yyyy-MM-dd&quot;,&quot;1990-01-01&quot;),&#xD;&#xA;    row1.index,&#xD;&#xA;    &quot;dd&quot;) " type="id_Date"/>
        <mapperTableEntries name="annee" expression="Integer.parseInt(TalendDate.formatDate(&quot;yyyy&quot;, Var.date)) " type="id_Integer"/>
        <mapperTableEntries name="mois" expression="Integer.parseInt(TalendDate.formatDate(&quot;MM&quot;, Var.date))" type="id_Integer"/>
        <mapperTableEntries name="jour" expression="Integer.parseInt(TalendDate.formatDate(&quot;dd&quot;, Var.date))" type="id_Integer"/>
        <mapperTableEntries name="semestre" expression="Var.mois &lt;= 6 ? 1 : 2 " type="id_Integer"/>
        <mapperTableEntries name="trimestre" expression="(Var.mois - 1) / 3 + 1" type="id_Integer"/>
      </varTables>
      <outputTables sizeState="INTERMEDIATE" name="out1" expressionFilter="Var.annee >= 1990 &amp;&amp; Var.annee &lt;= 2050" activateExpressionFilter="true">
        <mapperTableEntries name="Date_PK" expression="Integer.parseInt(TalendDate.formatDate(&quot;yyyyMMdd&quot;, Var.date)) " type="id_Integer" nullable="true"/>
        <mapperTableEntries name="Date" expression="Var.date " type="id_Date" nullable="true"/>
        <mapperTableEntries name="Jour_Moi_Annee" expression="new java.text.SimpleDateFormat(&quot;d - MMMM - yyyy&quot;, java.util.Locale.FRENCH).format(Var.date) " type="id_String" nullable="true"/>
        <mapperTableEntries name="Annee" expression="Var.annee" type="id_Integer" nullable="true"/>
        <mapperTableEntries name="ID_Semestre" expression="String.valueOf(Var.annee) + &quot; Semestre &quot; + String.valueOf(Var.semestre) " type="id_String" nullable="true"/>
        <mapperTableEntries name="Semestre" expression="&quot;Semestre &quot; + String.valueOf(Var.semestre) " type="id_String" nullable="true"/>
        <mapperTableEntries name="ID_Trimestre" expression="String.valueOf(Var.annee) + &quot; Trimestre &quot; + String.valueOf(Var.trimestre) " type="id_String" nullable="true"/>
        <mapperTableEntries name="Trimestre" expression="&quot;Trimestre &quot; + String.valueOf(Var.trimestre) " type="id_String" nullable="true"/>
        <mapperTableEntries name="ID_Mois" expression="Integer.parseInt(TalendDate.formatDate(&quot;yyyyMM&quot;, Var.date)) " type="id_Integer" nullable="true"/>
        <mapperTableEntries name="Mois" expression="Var.mois " type="id_Integer" nullable="true"/>
        <mapperTableEntries name="Lib_Mois" expression="new java.text.SimpleDateFormat(&quot;MMMM&quot;, java.util.Locale.FRENCH).format(Var.date) " type="id_String" nullable="true"/>
        <mapperTableEntries name="Jour" expression="Var.jour " type="id_Integer" nullable="true"/>
        <mapperTableEntries name="Id_Lib_Jour" expression="Integer.parseInt(TalendDate.formatDate(&quot;u&quot;, Var.date)) " type="id_Integer" nullable="true"/>
        <mapperTableEntries name="Lib_Jour" expression="new java.text.SimpleDateFormat(&quot;EEEE&quot;, java.util.Locale.FRENCH).format(Var.date) " type="id_String" nullable="true"/>
        <mapperTableEntries name="Semaine" expression="Integer.parseInt(TalendDate.formatDate(&quot;ww&quot;, Var.date)) " type="id_Integer" nullable="true"/>
        <mapperTableEntries name="JourDeAnnee" expression="Integer.parseInt(TalendDate.formatDate(&quot;DDD&quot;, Var.date)) " type="id_Integer" nullable="true"/>
        <mapperTableEntries name="Jour_mois_lettre" expression="new java.text.SimpleDateFormat(&quot;EEEE - d - MMMM&quot;, java.util.Locale.FRENCH).format(Var.date) " type="id_String" nullable="true"/>
      </outputTables>
      <inputTables sizeState="INTERMEDIATE" name="row1" matchingMode="UNIQUE_MATCH" lookupMode="LOAD_ONCE">
        <mapperTableEntries name="index" type="id_Integer" nullable="true"/>
      </inputTables>
    </nodeData>
  </node>
